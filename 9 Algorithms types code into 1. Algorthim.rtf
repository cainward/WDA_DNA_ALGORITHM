def evolutionary_algorithm(pop_size=10, num_generations=5):\par
    population = [np.random.rand(10) for _ in range(pop_size)]  # Random initialization\par
    \par
    for generation in range(num_generations):\par
        population = sorted(population, key=lambda x: sum(x))  # Sort based on fitness\par
        parents = population[:2]\par
        \par
        # Crossover\par
        offspring = [random.choice(parents) + random.choice(parents) for _ in range(pop_size - 2)]\par
